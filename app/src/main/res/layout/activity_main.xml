<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center_horizontal"
    android:background="#FF0F0F1A">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="DawnTranslator"
        android:textSize="28sp"
        android:textColor="#FFD4AF37"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Офлайн-переводчик англ → рус для Dawncaster"
        android:textSize="14sp"
        android:textColor="#FF888888"
        android:gravity="center"
        android:layout_marginBottom="32dp" />

    <TextView
        android:id="@+id/status_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Инициализация…"
        android:textSize="15sp"
        android:textColor="#FFCCCCCC"
        android:gravity="center"
        android:padding="16dp"
        android:background="#22FFFFFF"
        android:layout_marginBottom="24dp" />

    <Button
        android:id="@+id/btn_overlay_permission"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Дать разрешение на оверлей"
        android:textSize="16sp"
        android:layout_marginBottom="12dp" />

    <Button
        android:id="@+id/btn_accessibility"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Открыть настройки Accessibility"
        android:textSize="16sp"
        android:layout_marginBottom="32dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Как пользоваться:\n\n1. Дайте разрешение на оверлей\n2. Включите DawnTranslator в Accessibility\n3. Откройте Dawncaster — перевод появится автоматически\n\nСловарь терминов можно дополнить в приложении."
        android:textSize="13sp"
        android:textColor="#FF777777"
        android:lineSpacingMultiplier="1.3" />

</LinearLayout>
